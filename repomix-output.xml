                        ? 'text-amber-600'
                        : 'text-rose-600'
                    }`}>
                      {facility.gapsCount}
                    </span>
                  </div>
                </div>

                {/* View Details Button */}
                <div className="px-6 pb-6">
                  <button
                    onClick={() => setSelectedFacilityId(facility.id)}
