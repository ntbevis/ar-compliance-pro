            <div className="text-blue-500 font-black tracking-[0.25em] uppercase text-[11px] animate-pulse text-center leading-loose">
              Mapping Arkansas Code Frameworks <br /> & Instantiating Corporate Hub...
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
